# ===== Server =====
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# Business timezone (Ghana). Used for now(), order dates and analytics buckets.
APP_TIMEZONE=Africa/Accra
# Public HTTPS URL of this API (for registering Shopify webhooks). e.g. https://api.nuruya.com
APP_PUBLIC_URL=

# ===== PostgreSQL =====
PGHOST=localhost
PGPORT=5432
PGDATABASE=nuruya_crm
PGUSER=Sambatra
PGPASSWORD=20241002
PGSSL=false
PG_POOL_MAX=10

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== Security =====
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ===== Shopify =====
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=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
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=

# ===== ShaQ =====
SHAQ_API_BASE=https://public-api.shaqexpress.com
SHAQ_API_KEY=
SHAQ_WEBHOOK_SECRET=
