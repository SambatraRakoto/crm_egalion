# ===== Server =====
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
# Business timezone (Ghana). Used for now(), order dates and analytics buckets.
APP_TIMEZONE=Africa/Accra
# Public HTTPS URL of this API (for registering Shopify webhooks). e.g. https://api.nuruya.com
APP_PUBLIC_URL=

# ===== PostgreSQL =====
PGHOST=localhost
PGPORT=5432
PGDATABASE=nuruya_crm
PGUSER=Sambatra
PGPASSWORD=20241002
PGSSL=false
PG_POOL_MAX=10

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== Security =====
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ===== Shopify =====
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=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
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=
# Safety-net reconcile job: minutes between automatic re-pulls of recent Shopify
# orders (idempotent upsert) to catch missed webhooks & re-assert Shopify amounts.
# 0 disables it (default). NOTE: re-asserts Shopify as source of truth for
# customer/region/address/amount on recent orders — would revert manual CRM edits
# to those fields. delivery_status / dates / tracking are never touched.
SHOPIFY_RECONCILE_MINUTES=0

# ===== ShaQ =====
# Test partner API base (verified working). Production base may differ — confirm with ShaQ.
SHAQ_API_BASE=https://test-partner.shaqexpress.com/api/v1
SHAQ_IDENTIFIER=
SHAQ_SECRET=
SHAQ_WEBHOOK_SECRET=
# Auto-ship every received Shopify order to ShaQ. Defaults to ON when identifier
# + secret are set. Force with true/false. Set to false to pause auto-shipping.
SHAQ_AUTO_SHIP=true
# Catch-up job: minutes between automatic retries for Pending orders not yet
# shipped (e.g. received while ShaQ was down). 0 disables the job.
SHAQ_RETRY_INTERVAL_MINUTES=15
# Status-sync job: minutes between automatic polls of ShaQ for each tracked
# order's status progress (updates the CRM on change). 0 disables the job.
SHAQ_STATUS_SYNC_MINUTES=5
